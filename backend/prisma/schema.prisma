// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────
enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  CHECK
  TRANSFER
  WEBPAY
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

enum ChargeStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentSource {
  MANUAL
  PORTAL
}

enum FinancialSetupStatus {
  PENDING
  CONFIGURED
}

enum NotificationType {
  BOLETA_DELIVERY
  PAYMENT_RECEIPT
  COBRANZA_PREVENTIVA
  COBRANZA_MORA
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum CommunicationType {
  BOLETA_EMITTED
  MANUAL_PAYMENT_RECEIPT
  PAYMENT_REMINDER
  ACCOUNT_STATEMENT
}

enum DeliveryStatus {
  SENT
  FAILED
}

// ─── Models ──────────────────────────────────────────────────

model Tenant {
  id                 String              @id
  name               String
  slug               String              @unique
  isActive           Boolean             @default(true)
  courses            Course[]
  guardians          Guardian[]
  students           Student[]
  paymentConcepts    PaymentConcept[]
  paymentGroups      PaymentGroup[]
  payments           Payment[]
  charges            Charge[]
  notificationLogs   NotificationLog[]
  sentCommunications SentCommunication[]
  users              User[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("tenants")
}

model Course {
  id        Int       @id @default(autoincrement())
  tenantId  String    @default("colegio-conquistadores")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("courses")
}

model Guardian {
  id            Int       @id @default(autoincrement())
  tenantId      String    @default("colegio-conquistadores")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  rut           String?
  /**
   * Derivado en BD para búsqueda sin puntos/guiones
   */
  rutNormalized String?   @default(dbgenerated()) @map("rut_normalized")
  name          String
  email         String?
  phone         String?
  students      Student[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@unique([tenantId, rut])
  @@index([tenantId])
  @@map("guardians")
}

model Student {
  id               Int                  @id @default(autoincrement())
  tenantId         String               @default("colegio-conquistadores")
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  rut              String
  /**
   * Derivado en BD para búsqueda sin puntos/guiones
   */
  rutNormalized    String?              @default(dbgenerated()) @map("rut_normalized")
  name             String
  status           StudentStatus        @default(ACTIVE)
  financialSetup   FinancialSetupStatus @default(PENDING)
  courseId         Int
  guardianId       Int
  course           Course               @relation(fields: [courseId], references: [id])
  guardian         Guardian             @relation(fields: [guardianId], references: [id])
  payments         Payment[]
  charges          Charge[]
  notificationLogs NotificationLog[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  @@unique([tenantId, rut])
  @@index([tenantId])
  @@map("students")
}

model PaymentConcept {
  id            Int       @id @default(autoincrement())
  tenantId      String    @default("colegio-conquistadores")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  name          String
  defaultAmount Int
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  payments      Payment[]
  charges       Charge[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("payment_concepts")
}

model PaymentGroup {
  id                Int               @id @default(autoincrement())
  tenantId          String            @default("colegio-conquistadores")
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  buyOrder          String?
  authorizationCode String?
  cardLast4         String?
  totalAmount       Int
  method            PaymentMethod
  paymentDate       DateTime
  boletaFileUrl     String?
  boletaNumber      String?
  notes             String?
  source            PaymentSource     @default(MANUAL)
  isBoletaPending   Boolean           @default(false)
  payments          Payment[]
  notificationLogs  NotificationLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@unique([tenantId, buyOrder])
  @@index([tenantId])
  @@map("payment_groups")
}

model Payment {
  id          Int           @id @default(autoincrement())
  tenantId    String        @default("colegio-conquistadores")
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  amount      Int
  method      PaymentMethod
  source      PaymentSource @default(MANUAL)
  paymentDate DateTime
  studentId   Int
  student     Student       @relation(fields: [studentId], references: [id])

  paymentGroupId Int?
  paymentGroup   PaymentGroup? @relation(fields: [paymentGroupId], references: [id])

  // Concepto de pago (opcional para compatibilidad con registros anteriores)
  conceptId Int?
  concept   PaymentConcept? @relation(fields: [conceptId], references: [id])

  chargeId Int?
  charge   Charge? @relation(fields: [chargeId], references: [id])

  // Datos del pagador alternativo (null = pagó el apoderado)
  payerName String?
  payerRut  String?

  // Referencia y notas
  referenceCode String?
  notes         String?

  // Comprobante / boleta (pagos individuales legacy; agrupados usan PaymentGroup)
  boletaFileUrl String?
  boletaNumber  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@map("payments")
}

model Charge {
  id         Int            @id @default(autoincrement())
  tenantId   String         @default("colegio-conquistadores")
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  studentId  Int
  student    Student        @relation(fields: [studentId], references: [id])
  conceptId  Int
  concept    PaymentConcept @relation(fields: [conceptId], references: [id])
  amount     Int
  paidAmount Int            @default(0)
  dueDate    DateTime
  status     ChargeStatus   @default(PENDING)
  notes      String?
  payments   Payment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  @@index([tenantId])
  @@map("charges")
}

model NotificationLog {
  id             Int                @id @default(autoincrement())
  tenantId       String             @default("colegio-conquistadores")
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  type           NotificationType
  status         NotificationStatus @default(PENDING)
  recipientEmail String
  subject        String
  body           String
  errorMessage   String?
  retryCount     Int                @default(0)
  studentId      Int?
  student        Student?           @relation(fields: [studentId], references: [id])
  paymentGroupId Int?
  paymentGroup   PaymentGroup?      @relation(fields: [paymentGroupId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  @@index([tenantId])
  @@index([tenantId, status, retryCount])
  @@map("notification_logs")
}

model SentCommunication {
  id             String            @id @default(uuid())
  tenantId       String            @default("colegio-conquistadores")
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  recipientEmail String
  recipientName  String?
  type           CommunicationType
  subject        String
  status         DeliveryStatus
  metadata       Json?
  errorMessage   String?
  createdAt      DateTime          @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, status])
  @@map("sent_communications")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // Ej: "ADMIN", "CONTADOR"
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  action    String   @unique // Ej: "create:payment", "view:users"
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permissions")
}
