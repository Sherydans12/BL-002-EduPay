// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────
enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  CHECK
  TRANSFER
}

// ─── Models ──────────────────────────────────────────────────

model Course {
  id        Int       @id @default(autoincrement())
  name      String
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("courses")
}

model Guardian {
  id        Int       @id @default(autoincrement())
  rut       String?   @unique
  /** Derivado en BD para búsqueda sin puntos/guiones */
  rutNormalized String?  @default(dbgenerated("regexp_replace(upper(COALESCE(rut, '')), '[^0-9K]', '', 'g')")) @map("rut_normalized")
  name      String
  email     String?
  phone     String?
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("guardians")
}

model Student {
  id         Int       @id @default(autoincrement())
  rut        String    @unique
  /** Derivado en BD para búsqueda sin puntos/guiones */
  rutNormalized String   @default(dbgenerated("regexp_replace(upper(COALESCE(rut, '')), '[^0-9K]', '', 'g')")) @map("rut_normalized")
  name       String
  courseId    Int
  guardianId Int
  course     Course    @relation(fields: [courseId], references: [id])
  guardian   Guardian  @relation(fields: [guardianId], references: [id])
  payments   Payment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@map("students")
}

model PaymentConcept {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  defaultAmount Int
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  payments      Payment[]

  @@map("payment_concepts")
}

model PaymentGroup {
  id            Int           @id @default(autoincrement())
  totalAmount   Int
  method        PaymentMethod
  paymentDate   DateTime
  boletaFileUrl String?
  boletaNumber  String?
  notes         String?
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@map("payment_groups")
}

model Payment {
  id            Int              @id @default(autoincrement())
  amount        Int
  method        PaymentMethod
  paymentDate   DateTime
  studentId     Int
  student       Student          @relation(fields: [studentId], references: [id])

  paymentGroupId Int?
  paymentGroup   PaymentGroup?   @relation(fields: [paymentGroupId], references: [id])

  // Concepto de pago (opcional para compatibilidad con registros anteriores)
  conceptId     Int?
  concept       PaymentConcept?  @relation(fields: [conceptId], references: [id])

  // Datos del pagador alternativo (null = pagó el apoderado)
  payerName     String?
  payerRut      String?

  // Referencia y notas
  referenceCode String?
  notes         String?

  // Comprobante / boleta (pagos individuales legacy; agrupados usan PaymentGroup)
  boletaFileUrl String?
  boletaNumber  String?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("payments")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // Ej: "ADMIN", "CONTADOR"
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  action    String   @unique // Ej: "create:payment", "view:users"
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permissions")
}
