# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edupay?schema=public"

# ─── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT (OBLIGATORIO — no existe fallback; mínimo 32 caracteres aleatorios) ──
JWT_SECRET="CHANGE_ME_a_random_secret_key_min_32_chars"

# ─── CORS (OBLIGATORIO en producción) ────────────────────────
# En producción este valor restringe estrictamente el origen permitido.
FRONTEND_URL="https://tu-dominio.cl"

# ─── SMTP (cPanel nativo) ────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT=25
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@colegio.cl"

# ─── Upload ──────────────────────────────────────────────────
# Ruta relativa al cwd del proceso. Se resuelve con path.resolve(cwd, UPLOAD_DIR).
# En cPanel/Passenger asegúrate de que el directorio exista y sea escribible.
UPLOAD_DIR="uploads"
