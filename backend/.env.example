# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edupay?schema=public"

# ─── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT (OBLIGATORIO — no existe fallback; mínimo 32 caracteres aleatorios) ──
JWT_SECRET="CHANGE_ME_a_random_secret_key_min_32_chars"

# ─── Portal de Pagos (Server-to-Server) ──────────────────────
# Debe ser el mismo secreto configurado como Bearer Token en el BFF.
EDUPAY_API_KEY="CHANGE_ME_a_random_portal_api_key"

# ─── CORS (OBLIGATORIO en producción) ────────────────────────
# En producción este valor restringe estrictamente el origen permitido.
FRONTEND_URL="https://tu-dominio.cl"

# ─── Email ───────────────────────────────────────────────────
# Pon ENABLE_EMAILS=true solo cuando tengas SMTP configurado.
# Con false (por defecto) los correos se simulan en consola: Zero-Cost Mode.
ENABLE_EMAILS=false

SMTP_HOST="smtp.ejemplo.cl"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@colegio.cl"

# ─── Upload ──────────────────────────────────────────────────
# Ruta relativa al cwd del proceso. En Docker el volumen se monta en /usr/src/app/uploads.
UPLOAD_DIR="uploads"
