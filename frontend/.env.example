# ─── API ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── Entorno ──────────────────────────────────────────────────
NODE_ENV=development

# ─── JWT (OBLIGATORIO — sin fallback; debe coincidir exactamente con backend JWT_SECRET) ──
JWT_SECRET=CHANGE_ME_must_match_backend

